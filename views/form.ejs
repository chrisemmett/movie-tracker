<%- include('partials/header', { pageTitle: movie.id ? 'Edit title' : 'Add title' }) %>

<a class="back" href="<%= movie.id ? '/movies/' + movie.id : '/' %>">&larr; Cancel</a>

<h1><%= movie.id ? 'Edit title' : 'Add a title' %></h1>

<section class="omdb-search">
  <h2>Look up on OMDB</h2>
  <p class="muted">Search by title, pick the right match, and we'll fill in the details and save them locally.</p>
  <div class="omdb-controls">
    <input type="search" id="omdb-query" placeholder="e.g. Blade Runner 2049" value="<%= movie.title || '' %>" />
    <button class="btn" type="button" id="omdb-search-btn">Search OMDB</button>
  </div>
  <div id="omdb-status" class="muted"></div>
  <ul id="omdb-results" class="omdb-results"></ul>
</section>

<form class="movie-form" method="<%= method %>" action="<%= action %>" enctype="multipart/form-data">
  <div class="field">
    <label for="title">Title <span class="req">*</span></label>
    <input type="text" id="title" name="title" required value="<%= movie.title || '' %>" />
  </div>

  <div class="field-row">
    <div class="field">
      <label for="format">Format</label>
      <select id="format" name="format">
        <% formats.forEach(function(f){ %>
          <option value="<%= f %>" <%= movie.format === f ? 'selected' : '' %>><%= f %></option>
        <% }); %>
      </select>
    </div>
    <div class="field">
      <label for="studio">Studio</label>
      <input type="text" id="studio" name="studio" value="<%= movie.studio || '' %>" />
    </div>
    <div class="field">
      <label for="distributor">Distributor</label>
      <input type="text" id="distributor" name="distributor" value="<%= movie.distributor || '' %>" />
    </div>
  </div>

  <div class="field">
    <label for="image">Cover image <span class="muted">(stored on your NAS)</span></label>
    <input type="file" id="image" name="image" accept="image/*" />
    <% var current = movie.image_file ? ('/uploads/' + movie.image_file) : (movie.poster_url || null); %>
    <% if (current) { %>
      <div class="current-image">
        <span class="muted">Current:</span>
        <img src="<%= current %>" alt="current cover" />
      </div>
    <% } %>
    <div id="omdb-poster-preview" class="current-image" hidden>
      <span class="muted">From OMDB:</span>
      <img id="omdb-poster-img" src="" alt="OMDB poster" />
    </div>
  </div>

  <details class="enrichment" <%= movie.imdb_id ? 'open' : '' %>>
    <summary>OMDB details (saved locally)</summary>
    <div class="enrichment-grid">
      <% var fields = [
        ['year','Year'],['rated','Rated'],['runtime','Runtime'],['genre','Genre'],
        ['director','Director'],['writer','Writer'],['actors','Cast'],['released','Released'],
        ['language','Language'],['country','Country'],['imdb_rating','IMDb rating'],['imdb_id','IMDb ID']
      ]; %>
      <% fields.forEach(function(f){ %>
        <div class="field">
          <label for="<%= f[0] %>"><%= f[1] %></label>
          <input type="text" id="<%= f[0] %>" name="<%= f[0] %>" value="<%= movie[f[0]] || '' %>" />
        </div>
      <% }); %>
      <div class="field field-wide">
        <label for="plot">Plot</label>
        <textarea id="plot" name="plot" rows="3"><%= movie.plot || '' %></textarea>
      </div>
    </div>
    <input type="hidden" id="poster_url" name="poster_url" value="<%= movie.poster_url || '' %>" />
    <input type="hidden" id="omdb_raw" name="omdb_raw" value="" />
  </details>

  <div class="actions">
    <button class="btn btn-primary" type="submit"><%= movie.id ? 'Save changes' : 'Add to collection' %></button>
    <a class="btn btn-ghost" href="<%= movie.id ? '/movies/' + movie.id : '/' %>">Cancel</a>
  </div>
</form>

<script src="/public/form.js"></script>

<%- include('partials/footer') %>
