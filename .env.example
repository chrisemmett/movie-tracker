# Copy to .env and adjust. docker-compose reads this automatically.

# Port the app is exposed on (host side)
APP_PORT=3000

# MySQL settings (used by both the app and the db container)
DB_NAME=movietracker
DB_USER=movietracker
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too

# OMDB API key — get a free one at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=
